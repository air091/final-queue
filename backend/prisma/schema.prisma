// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                    String @id @default(uuid())
  skillLevel            String?
  profileUrl            String?
  username              String
  email                 String @unique
  password              String
  status                String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  communities           Community[]
  hostedPlayers         HostedPlayers[]
}

model Community {
  id                    String @id @default(uuid())
  profileUrl            String?
  adminId               String
  communityName         String
  description           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  admin                 Account @relation(fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  hosts                 Host[]

  @@index([adminId])
}

enum HostStatus {
  available
  unavailable
}

model Host {
  id                    String @id @default(uuid())
  communityId           String
  hostName              String
  sportName             String
  status                HostStatus @default(available)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  community             Community @relation(fields: [communityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  hostedPlayers         HostedPlayers[]

  @@index([communityId])
}

enum PlayerStatus {
  waiting
  queued
  court
}

model HostedPlayers {
  id                   String @id @default(uuid())
  hostId               String
  playerId             String
  status               PlayerStatus @default(waiting)
  addedAt              DateTime @default(now())
  requestedAt          DateTime @default(now())
  acceptedAt           DateTime? 
  rejectedAt           DateTime?
  updatedAt            DateTime @updatedAt @default(now())
  host                 Host @relation(fields: [hostId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  player               Account @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([hostId, playerId])
  @@index([hostId])
  @@index([playerId])
}

model match {
  id                  String @id @default(uuid())
  hostId              String
  name                String
}

model queue {
  id                  String @id @default(uuid())
  hostId              String
  name                String
}