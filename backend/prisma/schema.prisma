// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SkillLevel {
  beginner
  intermediate
  advanced
  elite
}

enum AccountStatus {
  active
}

model Account {
  id                    String @id @default(uuid())
  skillLevel            SkillLevel @default(beginner)
  profileUrl            String @default("https://image.pngaaa.com/189/734189-middle.png")
  username              String
  email                 String @unique
  password              String
  status                AccountStatus @default(active)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  communities           Community[]
  hostedPlayers         HostedPlayer[]
  matchParticipants     MatchParticipant[]
}

model Community {
  id                    String @id @default(uuid())
  profileUrl            String @default("https://image.pngaaa.com/189/734189-middle.png")
  adminId               String
  communityName         String
  description           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  admin                 Account @relation(fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  hosts                 Host[]

  @@index([adminId])
}

enum HostStatus {
  available
  unavailable
}

// HOST RELATIONSHIP

model Host {
  id                    String @id @default(uuid())
  communityId           String
  hostName              String
  sport                 String
  status                HostStatus @default(available)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  community             Community @relation(fields: [communityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  
  players               HostedPlayer[]
  courts                Court[]
  queues                Queue[]
  matches               Match[]
  pricing               HostPricing?

  @@index([communityId])
}

enum HostedPlayerStatus {
  requested
  accepted
  rejected
  banned
}

enum Currency {
  PHP
  USD
  EUR
}

enum PaymentStatus {
  unpaid
  paid
}

enum PaymentMethod {
  cash
  ewallet
}

model HostedPlayer {
  id                   String @id @default(uuid())
  hostId               String
  playerId             String?
  paymentStatus        PaymentStatus @default(unpaid)
  gamesPlayed          Int @default(0)
  staticName           String?
  staticProfileUrl     String?
  staticSkillLevel     SkillLevel?
  status               HostedPlayerStatus @default(requested)
  timerStartedAt       DateTime?
  updatedAt            DateTime @updatedAt

  host                 Host @relation(fields: [hostId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  player               Account? @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Match presence is derived:
  // waiting  => no queueEntry and no courtAssignment
  // inQueue  => queueEntry exists, or courtAssignment exists before the court starts
  // playing  => courtAssignment exists on a started court
  // timerStartedAt continues from waiting into queue,
  // resets when a game starts, and resets again when a game ends.
  queueEntry           QueueEntry?
  courtAssignment      CourtAssignment?
  matchParticipations  MatchParticipant[]
  payments             PlayerPayment[]

  @@unique([hostId, playerId])
  @@index([hostId, status, playerId])
  @@index([hostId, paymentStatus])
}

// QUEUE RELATIONSHIP

model Queue {
  id                  String @id @default(uuid())
  hostId              String
  name                String

  host                Host @relation(fields: [hostId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  entries             QueueEntry[]

  @@index([hostId])
}

model QueueEntry {
  id                  String @id @default(uuid())
  hostedPlayerId      String
  queueId             String
  position            Int
  assignedAt          DateTime @default(now())

  hostedPlayer        HostedPlayer @relation(fields: [hostedPlayerId], references: [id], onDelete: Cascade)
  queue               Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@unique([queueId, position])
  @@unique([hostedPlayerId])
  @@index([queueId])
}

// COURT RELATIONSHIP

model Court {
  id                  String @id @default(uuid())
  hostId              String
  name                String
  startedAt           DateTime?
  endedAt             DateTime?

  host                Host @relation(fields: [hostId], references: [id], onDelete: Cascade)
  assignments         CourtAssignment[]
  matches             Match[]

  @@index([hostId])
}

model CourtAssignment {
  id                  String @id @default(uuid())
  hostedPlayerId      String
  courtId             String
  position            Int
  assignedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  hostedPlayer        HostedPlayer @relation(fields: [hostedPlayerId], references: [id], onDelete: Cascade)
  court               Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([courtId, position])
  @@unique([hostedPlayerId])
  @@index([courtId])
}

enum MatchStatus {
  finished
  ongoing
}

model Match {
  id                  String @id @default(uuid())
  hostId              String
  courtId             String?
  status              MatchStatus @default(ongoing)
  startedAt           DateTime?
  endedAt             DateTime?
  teamWinner          String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  host                Host @relation(fields: [hostId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  court               Court? @relation(fields: [courtId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  participants        MatchParticipant[]

  @@index([hostId, status, startedAt])
  @@index([courtId])
}

model MatchParticipant {
  id                  String @id @default(uuid())
  matchId             String
  hostedPlayerId      String
  accountId           String?
  staticName          String?
  staticProfileUrl    String?
  staticSkillLevel    SkillLevel?
  team                String?
  result              String?
  joinedAt            DateTime @default(now())
  createdAt           DateTime @default(now())

  match               Match @relation(fields: [matchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  hostedPlayer        HostedPlayer @relation(fields: [hostedPlayerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  account             Account? @relation(fields: [accountId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([matchId, hostedPlayerId])
  @@index([matchId])
  @@index([hostedPlayerId])
  @@index([accountId])
}

model HostPricing {
  id                  String @id @default(uuid())
  hostId              String @unique
  entranceFee         Decimal @default(0) @db.Decimal(10, 2)
  perMatchFee         Decimal @default(0) @db.Decimal(10, 2)
  currency            Currency @default(PHP)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  host                Host @relation(fields: [hostId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model PlayerPayment {
  id                  String @id @default(uuid())
  hostedPlayerId      String
  amountExpected      Decimal @default(0) @db.Decimal(10, 2)
  amountPaid          Decimal @default(0) @db.Decimal(10, 2)
  currency            Currency @default(PHP)
  status              PaymentStatus @default(unpaid)
  method              PaymentMethod?
  providerReference   String?
  notes               String?
  paidAt              DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  hostedPlayer        HostedPlayer @relation(fields: [hostedPlayerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([hostedPlayerId])
}
