// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                    String @id @default(uuid())
  skillLevel            String?
  profileUrl            String?
  username              String
  email                 String @unique
  password              String
  status                String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  communities           Community[]
  hostedPlayers         HostedPlayer[]
}

model Community {
  id                    String @id @default(uuid())
  profileUrl            String?
  adminId               String
  communityName         String
  description           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  admin                 Account @relation(fields: [adminId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  hosts                 Host[]

  @@index([adminId])
}

enum HostStatus {
  available
  unavailable
}

model Host {
  id                    String @id @default(uuid())
  communityId           String
  hostName              String
  sport                 String
  status                HostStatus @default(available)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  community             Community @relation(fields: [communityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  
  players               HostedPlayer[] 
  courts                Court[]
  queues                Queue[]

  @@index([communityId])
}

enum PlayerStatus {
  waiting
  queued
  court
}

model HostedPlayer {
  id                   String @id @default(uuid())
  hostId               String
  playerId             String
  addedAt              DateTime @default(now())
  requestedAt          DateTime @default(now())
  acceptedAt           DateTime? 
  rejectedAt           DateTime?
  updatedAt            DateTime @updatedAt @default(now())

  host                 Host @relation(fields: [hostId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  player               Account @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  queueEntry           QueueEntry?
  courtAssignment      CourtAssignment?

  @@unique([hostId, playerId])
  @@index([hostId])
  @@index([playerId])
}

model Queue {
  id                  String @id @default(uuid())
  hostId              String
  name                String

  host                Host @relation(fields: [hostId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  entries             QueueEntry[]

  @@index([hostId])
}

model QueueEntry {
  id                  String @id @default(uuid())
  hostedPlayerId      String
  queueId             String
  position            Int
  assignedAt          DateTime @default(now())

  hostedPlayer        HostedPlayer @relation(fields: [hostedPlayerId], references: [id], onDelete: Cascade)
  queue               Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@unique([queueId, position])
  @@unique([hostedPlayerId])
  @@index([queueId])
}

model Court {
  id                  String @id @default(uuid())
  hostId              String
  name                String

  host                Host @relation(fields: [hostId], references: [id], onDelete: Cascade)
  assignments         CourtAssignment[]

  @@index([hostId])
}

model CourtAssignment {
  id                  String @id @default(uuid())
  hostedPlayerId      String
  courtId             String
  position            Int
  assignedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  hostedPlayer        HostedPlayer @relation(fields: [hostedPlayerId], references: [id], onDelete: Cascade)
  court               Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([courtId, position])
  @@unique([hostedPlayerId])
  @@index([courtId])
}
