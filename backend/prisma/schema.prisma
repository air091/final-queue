generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String             @id @default(uuid())
  profileUrl        String             @default("https://static.vecteezy.com/system/resources/previews/030/750/807/non_2x/user-icon-in-trendy-outline-style-isolated-on-white-background-user-silhouette-symbol-for-your-website-design-logo-app-ui-illustration-eps10-free-vector.jpg")
  username          String
  email             String             @unique
  password          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  role              UserRoles          @default(player)
  status            AccountStatuses    @default(active)
  communities       Community[]
  communityAdmins   CommunityAdmin[]
  communityPlayers  CommunityPlayer[]
  receivedCommunityAdminInvites CommunityAdminInvite[] @relation("ReceivedCommunityAdminInvites")
  sentCommunityAdminInvites     CommunityAdminInvite[] @relation("SentCommunityAdminInvites")
  receivedCommunityPlayerInvites CommunityPlayerInvite[] @relation("ReceivedCommunityPlayerInvites")
  sentCommunityPlayerInvites     CommunityPlayerInvite[] @relation("SentCommunityPlayerInvites")
  receivedFriendRequests FriendRequest[]   @relation("ReceivedFriendRequests")
  sentFriendRequests     FriendRequest[]   @relation("SentFriendRequests")
  matchParticipants MatchParticipant[]
  hostedPlayers     Player[]
  sports            UserSport[]
}

model UserSport {
  id         String      @id @default(uuid())
  accountId  String
  sport      Sports
  skillLevel SkillLevels @default(beginner)
  account    Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model Community {
  id            String   @id @default(uuid())
  profileUrl    String   @default("https://static.vecteezy.com/system/resources/previews/030/750/807/non_2x/user-icon-in-trendy-outline-style-isolated-on-white-background-user-silhouette-symbol-for-your-website-design-logo-app-ui-illustration-eps10-free-vector.jpg")
  communityName String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  masterId      String
  master        Account  @relation(fields: [masterId], references: [id], onDelete: Cascade)
  hosts         Host[]
  admins        CommunityAdmin[]
  adminInvites  CommunityAdminInvite[]
  playerInvites CommunityPlayerInvite[]
  players       CommunityPlayer[]

  @@index([masterId])
}

model CommunityPlayer {
  id          String    @id @default(uuid())
  communityId String
  accountId   String
  status      PlayerHostStatuses @default(accepted)
  addedAt     DateTime  @default(now())
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, accountId])
  @@index([communityId])
  @@index([accountId])
}

model CommunityAdmin {
  id          String    @id @default(uuid())
  communityId String
  accountId   String
  addedAt     DateTime  @default(now())
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, accountId])
  @@index([communityId])
  @@index([accountId])
}

model CommunityAdminInvite {
  id          String                     @id @default(uuid())
  communityId String
  inviterId   String
  inviteeId   String
  status      CommunityAdminInviteStatus @default(pending)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  community   Community                  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  inviter     Account                    @relation("SentCommunityAdminInvites", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee     Account                    @relation("ReceivedCommunityAdminInvites", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([inviteeId, status])
  @@index([inviterId])
  @@index([communityId])
}

model CommunityPlayerInvite {
  id          String                     @id @default(uuid())
  communityId String
  inviterId   String
  inviteeId   String
  status      CommunityAdminInviteStatus @default(pending)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  community   Community                  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  inviter     Account                    @relation("SentCommunityPlayerInvites", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee     Account                    @relation("ReceivedCommunityPlayerInvites", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([inviteeId, status])
  @@index([inviterId])
  @@index([communityId])
}

model Host {
  id          String       @id @default(uuid())
  communityId String
  hostName    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  status      HostStatus   @default(available)
  sport       String
  location    String?
  maxPlayers  Int          @default(0)
  startTime   DateTime?
  endTime     DateTime?
  courts      Court[]
  community   Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  pricing     HostPricing?
  matches     Match[]
  players     Player[]
  queues      Queue[]

  @@index([communityId])
}

model Player {
  id                  String             @id @default(uuid())
  hostId              String
  playerId            String
  paymentStatus       PaymentStatuses    @default(unpaid)
  gamesPlayed         Int                @default(0)
  hostStatus          PlayerHostStatuses @default(requested)
  isHost              Boolean            @default(false)
  timerStartedAt      DateTime?
  updatedAt           DateTime           @updatedAt
  requestedAt         DateTime           @default(now())
  courtAssignment     CourtAssignment?
  matchParticipations MatchParticipant[]
  host                Host               @relation(fields: [hostId], references: [id], onDelete: Cascade)
  player              Account            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  payments            PlayerPayment[]
  queueAssignment     QueueAssignment?

  @@unique([hostId, playerId])
  @@index([hostId, hostStatus, playerId])
  @@index([hostId, paymentStatus])
}

model Queue {
  id      String            @id @default(uuid())
  hostId  String
  name    String
  host    Host              @relation(fields: [hostId], references: [id], onDelete: Cascade)
  entries QueueAssignment[]

  @@index([hostId])
}

model QueueAssignment {
  id           String   @id @default(uuid())
  playerId     String   @unique
  queueId      String
  position     Int
  assignedAt   DateTime @default(now())
  hostedPlayer Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  queue        Queue    @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@unique([queueId, position])
  @@index([queueId])
}

model Court {
  id          String            @id @default(uuid())
  hostId      String
  name        String
  endedAt     DateTime?
  startedAt   DateTime?
  host        Host              @relation(fields: [hostId], references: [id], onDelete: Cascade)
  assignments CourtAssignment[]
  matches     Match[]

  @@index([hostId])
}

model CourtAssignment {
  id           String @id @default(uuid())
  courtId      String
  position     Int
  playerId     String @unique
  court        Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)
  hostedPlayer Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([courtId, position])
  @@index([courtId])
}

model Match {
  id           String             @id @default(uuid())
  hostId       String
  courtId      String?
  status       MatchStatus        @default(ongoing)
  startedAt    DateTime?
  endedAt      DateTime?
  teamWinner   String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  court        Court?             @relation(fields: [courtId], references: [id])
  host         Host               @relation(fields: [hostId], references: [id], onDelete: Cascade)
  participants MatchParticipant[]

  @@index([hostId, status, startedAt])
  @@index([courtId])
}

model MatchParticipant {
  id        String   @id @default(uuid())
  matchId   String
  accountId String?
  team      String?
  result    String?
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  playerId  String
  account   Account? @relation(fields: [accountId], references: [id])
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@index([accountId])
}

model HostPricing {
  id          String     @id @default(uuid())
  hostId      String     @unique
  entranceFee Decimal    @default(0) @db.Decimal(10, 2)
  perMatchFee Decimal    @default(0) @db.Decimal(10, 2)
  updatedAt   DateTime   @updatedAt
  currency    Currencies @default(PHP)
  expectedFee Decimal    @default(0) @db.Decimal(10, 2)
  host        Host       @relation(fields: [hostId], references: [id], onDelete: Cascade)
}

model PlayerPayment {
  id           String   @id @default(uuid())
  amountPaid   Decimal  @default(0) @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  playerId     String
  hostedPlayer Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

model FriendRequest {
  id          String              @id @default(uuid())
  requesterId String
  receiverId  String
  status      FriendRequestStatus @default(pending)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  requester   Account             @relation("SentFriendRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    Account             @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([requesterId, status])
  @@index([receiverId, status])
}

enum AccountStatuses {
  active
  inactive
}

enum UserRoles {
  player
  master
  static
}

enum SkillLevels {
  expert
  advanced
  upper_intermediate
  intermediate
  low_intermediate
  high_beginner
  beginner
  low_beginner
}

enum Sports {
  badminton
}

enum HostStatus {
  available
  unavailable
}

enum PaymentStatuses {
  unpaid
  paid
}

enum PaymentMethods {
  cash
  ewallet
}

enum PlayerHostStatuses {
  requested
  accepted
  rejected
  banned
}

enum FriendRequestStatus {
  pending
  accepted
  rejected
}

enum CommunityAdminInviteStatus {
  pending
  accepted
  rejected
}

enum MatchStatus {
  finished
  ongoing
}

enum Currencies {
  PHP
  USD
}
